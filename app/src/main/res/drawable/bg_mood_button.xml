<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="45"
                        android:endColor="#FF8E8E"
                        android:startColor="#FF6B6B"
                        android:type="linear"/>
                    <stroke android:width="3dp" android:color="#FF5555"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="45"
                        android:endColor="#FFA0A0"
                        android:startColor="#FF8E8E"
                        android:type="linear"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:bottom="3dp" android:left="3dp">
                <shape android:shape="oval">
                    <solid android:color="#F0F0F0"/>
                </shape>
            </item>
            <item android:top="1dp" android:right="1dp">
                <shape android:shape="oval">
                    <solid android:color="@color/white"/>
                    <stroke android:width="2dp" android:color="#E0E0E0"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
